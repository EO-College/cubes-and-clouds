monthly_mean.band(\"nir\")\n\nndvi = (nir - red) / (nir + red)\n\nndvi.execute().compute()\n\ntracker.stop_experiment()","key":"T6hyZe4Gt2"},{"type":"outputs","id":"Ar4A0jdgGGw6dwdIpVy-k","children":[],"key":"i1d2ki0XlQ"}],"key":"uCA2nAG2GY"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"strong","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Quiz hint: look carefully energy emission equivalents","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"avHeraddGt"}],"key":"RrDwR5u3na"}],"key":"KBg7Nl8Px2"}],"key":"xuoRNbyefK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"calculate_emission_equivalents(experiment_id=3)","key":"LIPFmqzJA0"},{"type":"outputs","id":"lSgI8uzvKX6x7mD_AHw4a","children":[],"key":"Zk3RBzPn8I"}],"key":"wptFQoB8gz"}],"key":"uxf5y66vxe"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"2.4 Scaling with Pangeo","url":"/lectures/formats-and-performance/exercises/dask","group":"Data formats for achieving scalability"},"next":{"title":"3.1 Data Processing","url":"/lectures/data-processing/data-processing","group":"Process & Share"}}},"domain":"http://localhost:3000"}